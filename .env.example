# ──────────────────────────────────────────────────────────────────────────
# Specter — environment variables
# Copy to .env.local and fill in. Anything left blank falls back to MOCK mode for
# local demos (no real money moves, no external calls), so the hero crash test
# is rehearsable without any sponsor keys.
# ──────────────────────────────────────────────────────────────────────────

# Anthropic
ANTHROPIC_API_KEY=
DETECTOR_MODEL=claude-haiku-4-5
AGENT_MODEL=claude-sonnet-4-6

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection — used ONLY to apply migrations (pnpm --filter @specter/db migrate)
SUPABASE_DB_URL=

# Stripe (test mode only — never a live key in this repo)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_API_VERSION=2026-04-22.preview

# Firecrawl
FIRECRAWL_API_KEY=

# Notifications — the human-in-the-loop is the in-app approval queue (Supabase
# Realtime) + a spoken alert in the dashboard. Email is an OPTIONAL heads-up sent
# fire-and-forget via Resend (never in the request path). Blank → not sent.
NOTIFICATION_EMAIL=
RESEND_API_KEY=
RESEND_FROM=Specter <onboarding@resend.dev>

# ElevenLabs (spoken incident alert; the dashboard falls back to the browser's
# built-in speech synthesis so the demo works with no key).
ELEVENLABS_API_KEY=

# Specter decision API
SPECTER_API_URL=http://localhost:8080
SPECTER_API_KEY=dev_tenant_key
SPECTER_PORT=8080

# Web app (Next.js PUBLIC vars — safe to ship to the browser; these are the ONLY
# vars that should be set in Vercel. Never put a service-role or secret key here.)
NEXT_PUBLIC_SPECTER_API_URL=http://localhost:8080
NEXT_PUBLIC_SPECTER_API_KEY=dev_tenant_key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
